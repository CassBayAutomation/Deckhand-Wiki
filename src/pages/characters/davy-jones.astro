---
import WikiLayout from '../../layouts/WikiLayout.astro';
---

<WikiLayout title="Davy Jones" section="characters">
  <div class="wiki-content">
    <div class="infobox">
      <div class="infobox-title">Davy Jones</div>
      <img src="/images/characters/davy-jones.png" alt="Davy Jones" class="infobox-image" />
      <table>
        <tr><td>Age</td><td>~190 years old</td></tr>
        <tr><td>Born</td><td>~1525</td></tr>
        <tr><td>Origin</td><td>Red Sea region</td></tr>
        <tr><td>Status</td><td>Immortal (cursed)</td></tr>
        <tr><td>Ship</td><td>The Tarshish</td></tr>
        <tr><td>Role</td><td>Antagonist / Employer</td></tr>
      </table>
    </div>

    <h1>Davy Jones</h1>
    <p>
      Davy Jones is the immortal captain of the sunken ship <em>The Tarshish</em>, bound to the ocean depths
      by a stolen flame that grants eternal life but burns only underwater. He commands the souls of the
      drowned, collects the dying, and has spent over a century in furious, heartbroken darkness, all
      because of <a href="/characters/mary-read">Grace O'Malley</a>.
    </p>

    <div class="stub-notice">
      <p>More information about Davy Jones will be added as the game develops.</p>
    </div>

