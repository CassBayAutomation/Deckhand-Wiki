</WikiLayout>

<style>
  .char-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2.5rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .char-nav-card {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 600;
    transition: border-color 0.2s, background 0.2s;
    min-width: 0;
    overflow: hidden;
  }

  .char-nav-card span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .char-nav-card:hover {
    border-color: var(--gold);
    background: rgba(240, 168, 0, 0.06);
    color: var(--text);
  }

  .char-nav-card img {
    width: 32px;
    height: 32px;
    object-fit: cover;
    object-position: top;
    border-radius: 4px;
    flex-shrink: 0;
  }

  .char-nav-card--next {
    flex-direction: row-reverse;
    text-align: right;
  }

  .char-nav-all {
    font-size: 0.85rem;
    color: rgba(0,0,0,0.45);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .char-nav-all:hover {
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .char-nav {
      flex-wrap: wrap;
    }

    .char-nav-all {
      order: -1;
      width: 100%;
      text-align: center;
      background: var(--off-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.6rem;
    }

    .char-nav-card {
      flex: 1;
    }

    .char-nav-card--next {
      flex-direction: row;
      text-align: left;
    }
  }
</style>
