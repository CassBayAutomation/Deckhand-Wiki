---
import WikiLayout from '../../layouts/WikiLayout.astro';
---

<WikiLayout title="Thomas Essex" section="characters">
  <div class="wiki-content">
    <div class="infobox">
      <div class="infobox-title">Thomas Essex</div>
      <img src="/images/characters/thomas-essex.gif" alt="Thomas Essex" class="infobox-image" />
      <table>
        <tr><td>Age</td><td>17</td></tr>
        <tr><td>Origin</td><td>Portsmouth, England</td></tr>
        <tr><td>Era</td><td>Golden Age of Piracy (~1715–1720)</td></tr>
        <tr><td>Class</td><td>Working class</td></tr>
        <tr><td>Status</td><td>Undead (resurrected by Davy Jones)</td></tr>
        <tr><td>Role</td><td>Protagonist</td></tr>
      </table>
    </div>

    <h1>Thomas Essex</h1>
    <p>
      Thomas "Tom" Essex is the protagonist of Davy Jones' Deckhand: a relentlessly optimistic 17-year-old
      Portsmouth deckhand who, after being unceremoniously murdered by pirates during his very first naval engagement,
      is resurrected by Davy Jones to serve as his agent aboard the high seas.
    </p>

    <div class="stub-notice">
      <p>More information about Thomas Essex will be added as the game develops.</p>
    </div>

