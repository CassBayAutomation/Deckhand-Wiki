---
import WikiLayout from '../../layouts/WikiLayout.astro';
import { getAttackCards } from '../../lib/cards.js';

const cards = getAttackCards();
---
<WikiLayout title="Attack Cards" section="cards">
  <div class="wiki-content">
    <h1>Attack Cards</h1>
    <p>Attack cards deal direct damage to enemies. They cost stamina to play and are the primary source of offensive pressure in combat.</p>

    <div class="card-grid">
      {cards.map(card => (
        <a href={`/cards/attack/${card.slug}?from=attack`} class="card-thumb">
          <img src={card.image} alt={card.title} loading="lazy" />
          <span class="card-thumb-name">{card.title}</span>
        </a>
      ))}
    </div>
  </div>
</WikiLayout>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(120px, 1fr));
    gap: 1rem;
    margin-top: 1.5rem;
  }

  .card-thumb {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    text-decoration: none;
    color: var(--text);
  }

  .card-thumb img {
    width: 100%;
    aspect-ratio: 2 / 3;
    object-fit: cover;
    border-radius: var(--radius);
    border: 2px solid var(--border);
    transition: border-color 0.2s, transform 0.2s;
  }

  .card-thumb:hover img {
    border-color: var(--gold);
    transform: translateY(-3px);
  }

  .card-thumb-name {
    font-size: 0.78rem;
    font-weight: 600;
    text-align: center;
    line-height: 1.2;
  }

  @media (max-width: 600px) {
    .card-grid {
      grid-template-columns: repeat(auto-fill, minmax(90px, 1fr));
      gap: 0.75rem;
    }
  }
</style>
