---
import WikiLayout from '../../../layouts/WikiLayout.astro';
import { getAllCards } from '../../../lib/cards.js';
import { linkKeywords, getStatusEffectTags } from '../../../utils/linkKeywords';
import { keywords } from '../../../data/keywords';

export async function getStaticPaths() {
  const { attack, technique, advantage, curse, stances } = getAllCards();
  const allCards = [
    ...attack.map(c => ({ ...c, type: 'attack', href: `/cards/attack/${c.slug}` })),
    ...technique.map(c => ({ ...c, type: 'technique', href: `/cards/technique/${c.slug}` })),
    ...advantage.map(c => ({ ...c, type: 'advantage', href: `/cards/advantage/${c.slug}` })),
    ...curse.map(c => ({ ...c, type: 'curse', href: `/cards/curse/${c.slug}` })),
    ...stances.map(c => ({ ...c, type: 'stance', href: `/cards/stances/${c.slug}` })),
  ].sort((a, b) => a.title.localeCompare(b.title));

  const typeCards = allCards.filter(c => c.type === 'stance');
  return typeCards.map((card) => {
    const idxAll = allCards.findIndex(c => c.href === card.href);
    const prevAll = allCards[idxAll > 0 ? idxAll - 1 : allCards.length - 1];
    const nextAll = allCards[idxAll < allCards.length - 1 ? idxAll + 1 : 0];
    const idxType = typeCards.findIndex(c => c.href === card.href);
    const prevType = typeCards[idxType > 0 ? idxType - 1 : typeCards.length - 1];
    const nextType = typeCards[idxType < typeCards.length - 1 ? idxType + 1 : 0];
    return { params: { slug: card.slug }, props: { card, prevAll, nextAll, prevType, nextType } };
  });
}

const { card, prevAll, nextAll, prevType, nextType } = Astro.props;

const statusTags = getStatusEffectTags(card.description || '');
const metaDescription = `${card.title} is a Stance card in Davy Jones' Deckhand.${card.description ? ' ' + card.description.replace(/\n/g, ' ').slice(0, 120) : ''}`;

const counterAttackTypeMap: Record<string, string> = {
  'Steady': 'Steady Parry',
  'Standard': 'Standard Parry',
  'Piercing': 'Piercing Parry',
};
const counterAttackTypeDisplay = card.counterAttackType
  ? (counterAttackTypeMap[card.counterAttackType] ?? card.counterAttackType)
  : '';

const counterKwSlug = card.counterAttackType && card.counterAttackType !== 'Standard'
  ? `counter-attack-${card.counterAttackType.toLowerCase()}-parry`
  : null;
const counterKw = counterKwSlug ? keywords.find(k => k.slug === counterKwSlug) : null;

// If the description is just the counter-attack type name, the tag already conveys that — leave effect blank
const counterTypeLabels = new Set(Object.values(counterAttackTypeMap).map(v => v.toUpperCase()));
const effectDescription = card.description && !counterTypeLabels.has(card.description.trim().toUpperCase())
  ? card.description
  : '';

// Build the infobox table as a string to avoid Astro's HTML parser
// dropping </table> when JSX conditional <tr> expressions are inside a <table>.
const infoboxTableHtml = [
  `<tr><td>${linkKeywords('Stamina Cost')}</td><td>${card.staminaCost !== null ? card.staminaCost : '—'}</td></tr>`,
  `<tr><td>Counter-attack Damage</td><td>${card.counterAttackDamage || '—'}</td></tr>`,
  `<tr><td>${linkKeywords('Max Parry')}</td><td>${card.maxParry || '—'}</td></tr>`,
  `<tr><td>${linkKeywords('Damage')}</td><td>${card.attackDamage || '—'}</td></tr>`,
  effectDescription ? `<tr><td>Effect</td><td class="desc-cell">${linkKeywords(effectDescription)}</td></tr>` : '',
  `<tr><td>Counter-attack Type</td><td>${linkKeywords(counterAttackTypeDisplay) || '—'}</td></tr>`,
].join('');
---
<WikiLayout title={card.title} section="cards" description={metaDescription} ogImage={card.image}>
  <div class="wiki-content">
    <div class="title-row">
      <h1>{card.title}</h1>
      <span class="tag tag-stance">Stance</span>
      {statusTags.map(t => (
        <a href={t.href} class="tag tag-status keyword-tip">
          {t.name}
          <span class="keyword-tip-popup">
            {t.image && <img src={t.image} alt={t.name} class="keyword-tip-img" />}
            <span class="keyword-tip-tag keyword-tip-tag--status">Status Effect</span>
            <span class="keyword-tip-desc">{t.description}</span>
          </span>
        </a>
      ))}
      {counterKwSlug && (
        <a href={`/keywords#${counterKwSlug}`} class="tag tag-counter keyword-tip">
          {counterAttackTypeMap[card.counterAttackType!] ?? card.counterAttackType}
          <span class="keyword-tip-popup">
            {counterKw?.image && <img src={counterKw.image} alt={counterKw.name} class="keyword-tip-img" />}
            {counterKw?.variant && <span class="keyword-tip-variant">{counterKw.variant}</span>}
            <span class="keyword-tip-desc">{counterKw?.description}</span>
          </span>
        </a>
      )}
    </div>

    <div class="card-layout">
      <img src={card.image} alt={card.title} class="card-img" />
      <div class="infobox">
        <div class="infobox-title">{card.title}</div>
        <table set:html={infoboxTableHtml}></table>
      </div>
    </div>

    {card.note && <p set:html={linkKeywords(card.note)} />}

    <div class="card-nav" id="card-nav-all">
      <a href={prevAll.href} class="card-nav-item">
        <img src={prevAll.image} alt={prevAll.title} />
        <span>← {prevAll.title}</span>
      </a>
      <a href="/cards" class="card-nav-all">All Cards</a>
      <a href={nextAll.href} class="card-nav-item card-nav-item--next">
        <img src={nextAll.image} alt={nextAll.title} />
        <span>{nextAll.title} →</span>
      </a>
    </div>
    <div class="card-nav" id="card-nav-type" style="display:none">
      <a href={`${prevType.href}?from=stances`} class="card-nav-item">
        <img src={prevType.image} alt={prevType.title} />
        <span>← {prevType.title}</span>
      </a>
      <a href="/cards/stances" class="card-nav-all">All Stance Cards</a>
      <a href={`${nextType.href}?from=stances`} class="card-nav-item card-nav-item--next">
        <img src={nextType.image} alt={nextType.title} />
        <span>{nextType.title} →</span>
      </a>
    </div>
    <script is:inline>
      if (new URLSearchParams(window.location.search).get('from') === 'stances') {
        document.getElementById('card-nav-all').style.display = 'none';
        document.getElementById('card-nav-type').removeAttribute('style');
      }
    </script>
  </div>
</WikiLayout>

<style>
  .title-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    margin-bottom: 1rem;
  }

  .title-row h1 {
    margin: 0;
  }

  .tag {
    display: inline-block;
    flex-shrink: 0;
  }

  .card-layout {
    display: grid;
    grid-template-columns: 220px 1fr;
    gap: 0 2rem;
    align-items: start;
    margin-bottom: 2rem;
  }

  .card-img {
    width: 100%;
    border-radius: var(--radius);
    border: 2px solid var(--border);
  }

  .infobox {
    float: none;
    width: 320px;
    margin: 0 0 0 auto;
  }

  .desc-cell {
    white-space: pre-line;
  }

  .card-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin-top: 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--border);
  }

  .card-nav-item {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    padding: 0.6rem 0.9rem;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    font-size: 0.9rem;
    font-weight: 600;
    transition: border-color 0.2s, background 0.2s;
    min-width: 0;
    overflow: hidden;
  }

  .card-nav-item span {
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
    min-width: 0;
  }

  .card-nav-item img {
    width: 28px;
    height: 42px;
    object-fit: cover;
    object-position: top;
    border-radius: 3px;
    flex-shrink: 0;
  }

  .card-nav-item:hover {
    border-color: var(--gold);
    background: rgba(240, 168, 0, 0.06);
  }

  .card-nav-item--next {
    flex-direction: row-reverse;
    text-align: right;
  }

  .card-nav-all {
    font-size: 0.85rem;
    color: rgba(0,0,0,0.45);
    text-decoration: none;
    white-space: nowrap;
    transition: color 0.2s;
  }

  .card-nav-all:hover {
    color: var(--gold);
  }

  @media (max-width: 600px) {
    .card-layout {
      grid-template-columns: 1fr;
    }

    .card-img {
      width: 180px;
      margin: 0 auto 1rem;
    }

    .card-nav {
      flex-wrap: wrap;
    }

    .card-nav-all {
      order: -1;
      width: 100%;
      text-align: center;
      background: var(--off-white);
      border: 1px solid var(--border);
      border-radius: var(--radius);
      padding: 0.6rem;
    }

    .card-nav-item {
      flex: 1;
    }

    .card-nav-item--next {
      flex-direction: row;
      text-align: left;
    }
  }
</style>
