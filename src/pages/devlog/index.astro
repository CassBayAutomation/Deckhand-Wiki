---
import WikiLayout from '../../layouts/WikiLayout.astro';
import { devlogEntries } from '../../data/devlog';
const entries = [...devlogEntries].reverse();
---
<WikiLayout title="Devlog" section="devlog" description="Development updates from Cass Bay Games — behind the scenes of Davy Jones' Deckhand.">
  <div class="wiki-content">
    <h1>Below Deck Newsletter</h1>
    <p>Below Deck is the Cass Bay Games newsletter and devlog. Read the latest updates from the team below.</p>
    <p>Want to receive the newsletter to your email? <a href="https://cassbaygames.m-pages.com/newsletter" target="_blank" rel="noopener">Sign up here</a>.</p>

    <div class="entry-list">
      {entries.map(entry => (
        <a href={`/devlog/${entry.slug}`} class="entry-card">
          {entry.thumbnail && (
            <img src={entry.thumbnail} alt={entry.title} class="entry-thumb" />
          )}
          <div class="entry-body">
            <span class="entry-date">{entry.date}</span>
            <h2 class="entry-title">{entry.title}</h2>
            <p class="entry-summary">{entry.summary}</p>
            <span class="entry-read">Read more →</span>
          </div>
        </a>
      ))}
    </div>
  </div>
</WikiLayout>

<style>
  .entry-list {
    display: flex;
    flex-direction: column;
    gap: 1rem;
    margin-top: 2rem;
  }

  .entry-card {
    display: flex;
    gap: 1.25rem;
    align-items: stretch;
    border: 1px solid var(--border);
    border-radius: var(--radius);
    text-decoration: none;
    color: var(--text);
    overflow: hidden;
    transition: border-color 0.2s, background 0.2s;
  }

  .entry-card:hover {
    border-color: var(--gold);
    background: rgba(240, 168, 0, 0.04);
    color: var(--text);
  }

  .entry-thumb {
    width: 300px;
    flex-shrink: 0;
    object-fit: cover;
    object-position: left center;
    display: block;
    clip-path: inset(0 2% 0 0);
  }

  .entry-body {
    padding: 1.25rem 1.25rem 1.25rem 0;
    display: flex;
    flex-direction: column;
  }

  .entry-date {
    display: block;
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.4rem;
  }

  .entry-title {
    font-size: 1.3rem;
    color: var(--navy);
    margin: 0 0 0.5rem;
    border: none;
    padding: 0;
  }

  .entry-summary {
    font-size: 0.92rem;
    color: var(--text-muted);
    margin: 0 0 0.75rem;
    line-height: 1.5;
  }

  .entry-read {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--ocean);
    margin-top: auto;
  }

  .entry-card:hover .entry-read {
    color: var(--gold-dark);
  }

  @media (max-width: 600px) {
    .entry-card {
      flex-direction: column;
    }

    .entry-thumb {
      width: 100%;
      height: 180px;
    }

    .entry-body {
      padding: 1rem;
    }
  }
</style>
